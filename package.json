{
  "name": "roomie-starter",
  "private": true,
  "scripts": {
    "dev": "npm --prefix web run dev",
    "build": "npm --prefix web run build",
    "typecheck": "npm --prefix web run typecheck",
    "lint": "npm --prefix web run lint",
    "check": "npm run typecheck && npm run lint && npm run build",
    "secret:scan": "node scripts/secret-scan.mjs",
    "release:hygiene": "node scripts/check-release-hygiene.mjs",
    "release:verify": "npm run release:hygiene && npm run secret:scan && npm run check",
    "supabase:start": "npx supabase start",
    "supabase:reset": "npx supabase db reset",
    "functions:serve": "npx supabase functions serve"
  },
  "dependencies": {
    "supabase": "^2.76.6"
  }
}
