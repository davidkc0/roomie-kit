# Required
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=

# Agora is the default media provider.
VITE_AGORA_APP_ID=

# Asset host for GLB, image, animation, emote, room, and furniture assets.
# "/" means "serve from web/public". Use a CDN/R2 URL later if you move assets back out.
VITE_ASSET_BASE_URL=/
# Backward-compatible alias for older Roomie deployments. Leave empty for new starters.
VITE_R2_BASE_URL=

# App identity and auth redirects.
VITE_APP_NAME=Roomie
VITE_PUBLIC_APP_URL=http://localhost:5173
VITE_DEEP_LINK_SCHEME=roomie
VITE_CAPACITOR_APP_ID=app.roomie.starter
VITE_APPLE_CLIENT_ID=app.roomie.starter
VITE_APPLE_REDIRECT_URI=http://127.0.0.1:54321/auth/v1/callback

# Optional public links shown in the app.
VITE_TERMS_URL=
VITE_PRIVACY_URL=
VITE_SUPPORT_EMAIL=support@example.com
VITE_COMMUNITY_URL=
VITE_INVITE_SHARE_URL=http://localhost:5173

# Optional product modules. Leave false/empty for the starter path.
VITE_ENABLE_WAITLIST=false
VITE_ENABLE_INVITES=false
VITE_ENABLE_ECONOMY=false
VITE_ENABLE_GIFTS=false
VITE_ENABLE_DAILY_REWARDS=false
VITE_ENABLE_PUSH=false
VITE_ONESIGNAL_APP_ID=
VITE_ENABLE_PAYMENTS=false
VITE_REVENUECAT_IOS_API_KEY=
